<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="com._1c.g5.wiring.serviceProvider">
      <bundle
            symbolicName="ru.xelgo.edt.contextlinks.ui">
      </bundle>
   </extension>

   <extension
         point="org.eclipse.core.runtime.preferences">
      <initializer
            class="ru.xelgo.edt.contextlinks.core.ContextLinksPreferenceInitializer">
      </initializer>
   </extension>

   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            class="ru.xelgo.edt.contextlinks.ui.ContextLinksPreferencePage"
            id="ru.xelgo.edt.contextlinks.ui.preferencePage"
            name="%pluginName">
      </page>
   </extension>

   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            category="org.eclipse.debug.ui"
            class="ru.xelgo.edt.contextlinks.ui.VariableSnapshotsView"
            icon="platform:/plugin/org.eclipse.debug.ui/icons/full/eview16/watchlist_view.png"
            id="ru.xelgo.edt.contextlinks.ui.views.variableSnapshots"
            name="%variableSnapshots.view.name"
            restorable="true">
      </view>
   </extension>

   <extension
         point="org.eclipse.ui.commands">
      <category
            id="ru.xelgo.edt.contextlinks.ui.category"
            name="%command.category.name">
      </category>
      <command
            categoryId="ru.xelgo.edt.contextlinks.ui.category"
            defaultHandler="ru.xelgo.edt.contextlinks.ui.ConfigureContextLinksHandler"
            id="ru.xelgo.edt.contextlinks.ui.commands.configureContextLinks"
            name="%command.name">
      </command>
      <command
            categoryId="ru.xelgo.edt.contextlinks.ui.category"
            id="ru.xelgo.edt.contextlinks.ui.commands.configureApplicationUpdateProjects"
            name="%applicationUpdate.command.name">
      </command>
   </extension>

   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="popup:com._1c.g5.v8.dt.navigator.ui.navigator.popup?endof=group.open">
         <command
               commandId="ru.xelgo.edt.contextlinks.ui.commands.configureContextLinks"
               style="push"
               tooltip="%command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="and">
                     <test
                           property="ru.xelgo.edt.contextlinks.ui.isContextConfigurableProject">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:com.e1c.g5.dt.applications.ui.view?after=additions">
         <separator
               name="ru.xelgo.edt.contextlinks.ui.applicationUpdate.separator"
               visible="true">
         </separator>
         <command
               commandId="ru.xelgo.edt.contextlinks.ui.commands.configureApplicationUpdateProjects"
               label="%applicationUpdate.command.name"
               style="push"
               tooltip="%applicationUpdate.command.tooltip">
            <visibleWhen
                  checkEnabled="true">
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>

   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="ru.xelgo.edt.contextlinks.ui.ConfigureApplicationUpdateProjectsHandler"
            commandId="ru.xelgo.edt.contextlinks.ui.commands.configureApplicationUpdateProjects">
         <enabledWhen>
            <with
                  variable="selection">
               <count
                     value="1">
               </count>
               <iterate
                     ifEmpty="false">
                  <instanceof
                        value="com.e1c.g5.dt.applications.IApplication">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
   </extension>

   <extension
         point="org.eclipse.core.expressions.propertyTesters">
      <propertyTester
            class="ru.xelgo.edt.contextlinks.ui.ContextLinksProjectPropertyTester"
            id="ru.xelgo.edt.contextlinks.ui.projectPropertyTester"
            namespace="ru.xelgo.edt.contextlinks.ui"
            properties="isExtensionProject,isContextConfigurableProject"
            type="java.lang.Object">
      </propertyTester>
   </extension>

   <extension
         point="org.eclipse.ui.startup">
      <startup
            class="ru.xelgo.edt.contextlinks.ui.ContextLinksStartup">
      </startup>
   </extension>

   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.eclipse.debug.ui.DebugPerspective">
         <view
               id="ru.xelgo.edt.contextlinks.ui.views.variableSnapshots"
               relationship="stack"
               relative="com._1c.g5.v8.dt.debug.ui.variables.BslExpressionsView"
               visible="true">
         </view>
         <viewShortcut
               id="ru.xelgo.edt.contextlinks.ui.views.variableSnapshots">
         </viewShortcut>
      </perspectiveExtension>
   </extension>

   <extension
         point="com._1c.g5.v8.dt.bsl.bslRuntimeModuleExtension">
      <bslRuntimeModuleExtension
            module="ru.xelgo.edt.contextlinks.core.ContextLinksBslRuntimeModule">
      </bslRuntimeModuleExtension>
   </extension>

   <extension
         point="com._1c.g5.v8.dt.bsl.ui.bslUiModuleExtension">
      <bslUiModuleExtension
            module="ru.xelgo.edt.contextlinks.core.ContextLinksBslFormatterUiModule">
      </bslUiModuleExtension>
   </extension>

   <extension
         point="com._1c.g5.v8.dt.bsl.ui.externalQuickfixProvider">
      <externalQuickfixProvider
            class="ru.xelgo.edt.contextlinks.core.ChangeAndValidateMergeQuickfixProvider">
      </externalQuickfixProvider>
   </extension>

   <extension
         point="com.e1c.g5.v8.dt.check.fixes">
      <fix
            class="ru.xelgo.edt.contextlinks.core.ChangeAndValidateMergeBslCheckQuickfix">
      </fix>
      <fix
            class="ru.xelgo.edt.contextlinks.core.ChangeAndValidateMergeMdExtensionCheckQuickfix">
      </fix>
      <fix
            class="ru.xelgo.edt.contextlinks.core.ChangeAndValidateMergeLegacyBslCheckQuickfix">
      </fix>
   </extension>

</plugin>
